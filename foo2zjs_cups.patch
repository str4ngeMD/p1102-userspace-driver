+void
+do_cups_raster(int fd)
+{
+    cups_raster_t       *ras;
+    cups_page_header2_t header;
+    int                 doc_started = 0;
+
+    OutputStartPlane = 0;
+
+    ras = cupsRasterOpen(fd, CUPS_RASTER_READ);
+    if (!ras)
+    {
+        fprintf(stderr, "ERROR: rastertozjs: cannot open raster stream\n");
+        exit(1);
+    }
+
+    while (cupsRasterReadHeader2(ras, &header))
+    {
+        int w = header.cupsWidth;
+        int h = header.cupsHeight;
+        int bpl = (w + 7) / 8;
+        int bpl16;
+        unsigned char *buf;
+        unsigned int y;
+        int invert;
+
+        // Map CUPS parameters to foo2zjs variables
+        PageWidth = w;
+        PageHeight = h;
+        ResX = header.HWResolution[0];
+        ResY = header.HWResolution[1];
+        
+        if (Model == MODEL_HP1020 || Model == MODEL_HP_PRO || Model == MODEL_HP_PRO_CP)
+        {
+            Bpp = ResX / 600;
+            ResX = 600;
+        }
+
+        if (!doc_started)
+        {
+            start_doc(stdout);
+            doc_started = 1;
+        }
+
+        switch (Model)
+        {
+        case MODEL_2300DL:    bpl16 = bpl; break;
+        case MODEL_HP1020:    bpl16 = (bpl + 15) & ~15; break;
+        case MODEL_HP_PRO:    bpl16 = (bpl + 15) & ~15; break;
+        case MODEL_HP_PRO_CP: bpl16 = (bpl + 15) & ~15; break;
+        default:              bpl16 = (bpl + 15) & ~15; break;
+        }
+
+        buf = calloc(bpl16, h);
+        if (!buf)
+        {
+            fprintf(stderr, "ERROR: rastertozjs: cannot allocate page buffer\n");
+            break;
+        }
+
+        for (y = 0; y < h; y++)
+        {
+            unsigned int n = cupsRasterReadPixels(ras, buf + (size_t)y * bpl16, header.cupsBytesPerLine);
+            if (n == 0) break;
+        }
+
+        // Invert pixels if the raster is inverted DeviceGray (1=white) instead of DeviceK (1=black)
+        invert = (header.cupsColorSpace == CUPS_CSPACE_W);
+        if (invert)
+        {
+            unsigned int i;
+            for (i = 0; i < bpl16 * h; i++)
+                buf[i] ^= 0xFF;
+        }
+
+        PageNum++;
+        pbm_page(buf, w, h, stdout);
+        free(buf);
+    }
+    if (doc_started)
+        end_doc(stdout);
+    cupsRasterClose(ras);
+}
